# Copy to .env.local and fill in. .env.local is gitignored.

# Required — powers the debrief questions + teachable-card compilation (Claude Sonnet 4.6).
ANTHROPIC_API_KEY=

# Recommended — Deepgram powers BOTH speech-to-text (nova-3 + keyterm prompting)
# and, by default, text-to-speech (Aura). Without it: type notes instead of recording,
# and no spoken questions.
DEEPGRAM_API_KEY=
DEEPGRAM_TTS_MODEL=aura-2-thalia-en

# Text-to-speech provider: "deepgram" (default, Aura) or "elevenlabs".
TTS_PROVIDER=deepgram

# Only needed if TTS_PROVIDER=elevenlabs.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
