# Copy to .env.local and fill in. .env.local is gitignored.

# Required — powers the AI debrief questions + teachable-card compilation.
ANTHROPIC_API_KEY=

# Recommended — speech-to-text for voice capture (Deepgram nova-3).
# Without it, the app still works: just type your notes instead of recording.
DEEPGRAM_API_KEY=

# Optional — "Hear it" reads the debrief questions aloud (ElevenLabs).
# Without it, questions display as text only.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
